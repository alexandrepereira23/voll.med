# =============================================================================
# Banco de Dados — MySQL
# Usadas tanto pelo Docker Compose quanto pela aplicação Spring Boot
# =============================================================================
DB_HOST=localhost
DB_PORT=3307
DB_NAME=vollmed_api
DB_USER=root
DB_PASSWORD=

# =============================================================================
# Segurança — JWT
# Gere um valor seguro com: openssl rand -base64 32
# =============================================================================
JWT_SECRET=

# Tempo de expiração do token em horas (padrão: 2)
# TOKEN_EXPIRACAO_HORAS=2

# =============================================================================
# Admin inicial
# Criado automaticamente na primeira inicialização se não existir nenhum admin.
# =============================================================================
ADMIN_LOGIN=admin@vollmed.com
ADMIN_PASSWORD=

# =============================================================================
# IA — Anthropic Claude API
# Obtenha em: https://console.anthropic.com/
# =============================================================================
ANTHROPIC_API_KEY=
